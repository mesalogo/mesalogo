# ====================================================================
# MesaLogo Docker Compose 环境变量(模板)
# Copy to: .env  and fill in your own values.  DO NOT commit .env.
# ====================================================================

# ================================
# Docker Compose 文件配置
# ================================
COMPOSE_FILE=docker-compose.yml:docker-compose.redis.yml:docker-compose.milvus.yml:docker-compose.graphiti.yml:docker-compose.lightrag.yml:docker-compose.onlyoffice.yml:docker-compose.galapagos.yml:docker-compose.vscode-server.yml:docker-compose.paddleocr-vl.yml:docker-compose.mariadb.yml

# ================================
# 可选服务开关
# ================================
# 可用 profiles: core, redis, milvus, graphiti, lightrag, onlyoffice,
#                galapagos, vscode-server, paddleocr-vl
# 留空则不自动启动任何服务,通过 make 命令按需启动
COMPOSE_PROFILES=

# ================================
# VSCode Server (可选)
# ================================
# 设置一个强密码,不要使用默认值
VSCODE_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
VSCODE_SUDO_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# ================================
# 镜像配置
# ================================
BACKEND_IMAGE=mesalogo/backend
FRONTEND_IMAGE=mesalogo/frontend
IMAGE_TAG=latest

# ================================
# MariaDB 配置
# ================================
# REQUIRED if you enable the mariadb profile. Use a strong random password.
MARIADB_ROOT_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
MARIADB_DATABASE=abm

# ================================
# Milvus 配置
# ================================
DOCKER_VOLUME_DIRECTORY=.

# ================================
# Graphiti / Neo4j 配置(记忆系统;可选,即将由 MemoryPalace v0.51 取代)
# ================================
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY_HERE
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
NEO4J_PORT=7687

# ================================
# LightRAG 配置(知识库系统)
# ================================
LIGHTRAG_PORT=9621

# ================================
# Redis 配置
# ================================
REDIS_URL=redis://redis:6379/0

# ================================
# 后端配置
# ================================
FLASK_ENV=production
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
LOG_LEVEL=INFO
PYTHONIOENCODING=utf-8
LC_ALL=C.UTF-8
LANG=C.UTF-8

# UV/UVX PyPI 镜像源(中国境内加速,如不需要可留官方)
UV_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
UV_EXTRA_INDEX_URL=https://pypi.org/simple/

# ================================
# 前端配置
# ================================
NODE_ENV=production
FRONTEND_PORT=3000
REACT_APP_API_URL=http://localhost:8080/api
