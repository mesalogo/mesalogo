# ====================================================================
# LightRAG 环境变量配置(模板)
# Copy to: lightrag.env  and fill in your own values.  DO NOT commit lightrag.env.
#
# 完整文档:https://github.com/HKUDS/LightRAG
# 这里只保留 MesaLogo 默认推荐的最小配置,完整选项请参考上游 .env.example
# ====================================================================

###########################
### Server Configuration
###########################
HOST=0.0.0.0
PORT=9621
WEBUI_TITLE=MesaLogo Knowledge Graph
WEBUI_DESCRIPTION="Simple and Fast Graph Based RAG System"

#####################################
### Login and API-Key Configuration
#####################################
# Set a strong key in production
# LIGHTRAG_API_KEY=YOUR_STRONG_API_KEY_HERE

###########################################################################
### LLM Configuration
### LLM_BINDING type: openai, ollama, lollms, azure_openai, aws_bedrock, gemini
###########################################################################
LLM_BINDING=openai
LLM_MODEL=qwen-plus-latest
LLM_BINDING_HOST=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_BINDING_API_KEY=sk-YOUR_LLM_API_KEY_HERE

#######################################################################################
### Embedding Configuration
#######################################################################################
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=qwen2.5-vl-embedding
EMBEDDING_DIM=1024
EMBEDDING_SEND_DIM=false
EMBEDDING_TOKEN_LIMIT=8192
EMBEDDING_BINDING_HOST=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_BINDING_API_KEY=sk-YOUR_EMBEDDING_API_KEY_HERE

#########################################################
### Reranking configuration
#########################################################
RERANK_BINDING=cohere
# RERANK_BINDING_API_KEY=YOUR_RERANK_API_KEY_HERE

########################################
### Document processing configuration
########################################
ENABLE_LLM_CACHE=true
ENABLE_LLM_CACHE_FOR_EXTRACT=true
SUMMARY_LANGUAGE=Chinese
CHUNK_SIZE=1200
CHUNK_OVERLAP_SIZE=100
TOP_K=40
MAX_TOTAL_TOKENS=30000

###############################
### Concurrency Configuration
###############################
MAX_ASYNC=4
MAX_PARALLEL_INSERT=2

############################
### Data storage selection
############################
LIGHTRAG_VECTOR_STORAGE=MilvusVectorDBStorage

### Milvus Configuration
MILVUS_URI=http://host.docker.internal:19530
MILVUS_DB_NAME=lightrag

### Redis
REDIS_URI=redis://localhost:6379

### PostgreSQL Configuration (optional, only if you switch to PG-based storage)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=YOUR_PG_USER
# POSTGRES_PASSWORD='YOUR_STRONG_PG_PASSWORD'
# POSTGRES_DATABASE=YOUR_PG_DB
